#!/usr/bin/env bash
# AgentOS shell wrapper — generated by agentosd on first launch.
# This script transparently intercepts AGENT_NAME launches so AgentOS can
# track the session lifecycle without any manual configuration.
#
# How it works:
#   1. Sends session_started to the daemon (fire-and-forget, 100ms timeout)
#   2. exec's the real binary with all original arguments
#   3. An EXIT trap sends session_completed / session_failed when the agent exits

set -euo pipefail

# ── Configuration ────────────────────────────────────────────────────────────
AGENT_NAME="AGENT_PLACEHOLDER"
AGENT_REAL_BIN="REAL_BIN_PLACEHOLDER"
SESSION_ID="$(cat /proc/sys/kernel/random/uuid 2>/dev/null || uuidgen 2>/dev/null || date +%s%N)"
DAEMON_SOCKET="${AGENTOSD_SOCK:-${HOME}/.agentosd.sock}"
HOOK_BIN="$(command -v agentos-hook 2>/dev/null || echo '')"

# ── Helper: fire-and-forget event ────────────────────────────────────────────
_send_event() {
    local payload="$1"
    if [[ -n "$HOOK_BIN" ]]; then
        # Use the compiled hook binary (fastest, no extra deps)
        timeout 0.1s "$HOOK_BIN" --source "$AGENT_NAME" --event "$payload" &>/dev/null &
    fi
    # Fallback: raw socat if hook binary not on PATH
}

# ── EXIT trap ─────────────────────────────────────────────────────────────────
_on_exit() {
    local exit_code=$?
    local event_type
    if [[ $exit_code -eq 0 ]]; then
        event_type="session_complete"
    else
        event_type="session_failed"
    fi
    _send_event "{\"type\":\"${event_type}\",\"session_id\":\"${SESSION_ID}\",\"pid\":$$}"
    # Wait for background send to complete (max 120ms)
    wait 2>/dev/null || true
}
trap '_on_exit' EXIT

# ── Signal session_started ────────────────────────────────────────────────────
_send_event "{\"type\":\"session_start\",\"session_id\":\"${SESSION_ID}\",\"pid\":$$,\"cwd\":\"$(pwd)\",\"model\":\"${AGENTOS_MODEL:-}\"}"

# ── Pass AgentOS socket to the agent via env ──────────────────────────────────
export AGENTOS_SESSION_ID="$SESSION_ID"

# ── Transparent passthrough ──────────────────────────────────────────────────
exec "$AGENT_REAL_BIN" "$@"
